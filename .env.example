NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── LLM Keys（至少配置一个）────────────────────────────────────────────────────
# Anthropic（优先使用，用于 rerank 和 Dream consolidate）
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI（备选 / fallback）
OPENAI_API_KEY=your_openai_key_here

# ── Memocore 配置 ─────────────────────────────────────────────────────────────

# Agent namespace (each user/project gets an isolated namespace, default "default")
MEMOCORE_AGENT_ID=my-agent

# LLM provider: anthropic | openai
# 留空则自动检测：优先 Anthropic（若 ANTHROPIC_API_KEY 存在），否则 OpenAI
# MEMOCORE_LLM_PROVIDER=anthropic

# 使用的模型（可选，有默认值）
# MEMOCORE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# MEMOCORE_OPENAI_MODEL=gpt-4o-mini

# Embedding provider: openai | local | auto（默认：有 OPENAI_API_KEY 用 openai，否则 local）
# MEMOCORE_EMBED_PROVIDER=auto

# 本地 embedding 模型（MEMOCORE_EMBED_PROVIDER=local 时生效）
# 安装依赖：pip install fastembed  或  pip install sentence-transformers
# MEMOCORE_LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5

# OpenAI embedding 模型
# MEMOCORE_EMBED_MODEL=text-embedding-3-small

# Dream 触发间隔（每隔多少次对话触发一次记忆巩固，默认 5）
# MEMOCORE_DREAM_INTERVAL=5

# 状态文件目录（默认 ~/.memocore）
# MEMOCORE_STATE_DIR=/path/to/custom/dir
